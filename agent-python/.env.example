# ========================================
# LLM 配置（必填）
# ========================================
DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60.0

# ========================================
# 外部服务（可选）
# ========================================
JAVA_BACKEND_URL=http://localhost:8080
JAVA_BACKEND_TIMEOUT=5.0

# ========================================
# 应用配置
# ========================================
APP_NAME=Job Agent API
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=5001

# ========================================
# 并发控制
# ========================================
MAX_CONCURRENT_STREAMS=1000
PER_USER_STREAM_LIMIT=5

# ========================================
# 超时设置
# ========================================
STREAM_TASK_TIMEOUT=600.0
CHUNK_TTL=3600

# ========================================
# 重试策略
# ========================================
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=1.0
LLM_RETRY_MAX_DELAY=30.0

# ========================================
# CORS
# ========================================
CORS_ALLOW_ORIGINS=*

# ========================================
# LangSmith（可选）
# ========================================
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=job-agent
