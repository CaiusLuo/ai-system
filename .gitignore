# Monorepo ignore rules for Java, Python, and frontend projects.

# OS generated files
.DS_Store
Thumbs.db
Desktop.ini

# Editor / IDE
.idea/
.vscode/
*.iml
*.ipr
*.iws
.classpath
.factorypath
.project
.settings/
.apt_generated/
.springBeans
.sts4-cache/
**/nbproject/private/
**/nbbuild/
**/nbdist/
**/.nb-gradle/

# Environment and local-only config
.env
.env.*
!.env.example
!.env.sample
!.env.template

# Logs and temporary files
*.log
logs/
tmp/
temp/
.cache/

# Java / JVM build output
target/
build/
out/
.gradle/

# Python
__pycache__/
*.py[cod]
*.pyc.*
*.pyo
*.pyd
*.py,cover
.coverage
.coverage.*
.hypothesis/
.ipynb_checkpoints/
.mypy_cache/
.nox/
.pyre/
.pytest_cache/
.ruff_cache/
.tox/
.venv/
ENV/
env/
htmlcov/
pip-wheel-metadata/
venv/
*.egg-info/
__pypackages__/

# Node / frontend
node_modules/
.angular/cache/
.next/
.nuxt/
.parcel-cache/
.pnpm-store/
.npm/
.svelte-kit/
.turbo/
.yarn/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
coverage/
dist/
storybook-static/
*.tsbuildinfo
.eslintcache
